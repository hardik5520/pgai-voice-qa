# Twilio (console.twilio.com). TWILIO_CALLER_NUMBER is the single number
# you buy/verify in Twilio and will use for every test call, in E.164 format.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_CALLER_NUMBER=+1XXXXXXXXXX

# OpenAI Realtime API key (platform.openai.com)
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_VOICE=alloy

# Public https URL that tunnels to this server (e.g. an ngrok forwarding
# URL). Twilio needs to reach this from the internet for both the call
# webhook and the media stream websocket.
PUBLIC_SERVER_URL=https://your-tunnel-subdomain.ngrok-free.app

PORT=8000
